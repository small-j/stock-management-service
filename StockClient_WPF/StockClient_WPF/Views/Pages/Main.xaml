<Page x:Class="StockClient_WPF.Views.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StockClient_WPF.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10,10,10,10" >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" Margin="0,0,10,10" Grid.Row="14" Height="35" Width="100" Background="CadetBlue" Foreground="white" Content="Add Item" Command="{Binding ViewModel.AddItemCommand}"/>
                <ui:Button Grid.Column="1" Margin="0,0,10,10" Grid.Row="14" Height="35" Width="70" Background="Black" Content="refresh" Command="{Binding ViewModel.GetItemsCommand}" />
            </Grid>
            <Grid x:Name="itemDgGrid" Grid.Column="1">
                <DataGrid Foreground="Black" ItemsSource="{Binding ViewModel.Items}" BorderBrush="Black" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"  Binding="{Binding Id}" />
                        <DataGridTextColumn Header="이름"  Binding="{Binding Name}" />
                        <DataGridTextColumn Header="아이템 종류" Binding="{Binding ItemType}" />

                        <!-- 버튼 열 추가 -->
                        <DataGridTemplateColumn Header="관리">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="삭제"
                                        Command="{Binding DataContext.ViewModel.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="10,10,10,10" >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" Margin="0,0,0,10" Grid.Row="14" Height="35" Width="100" Background="CadetBlue" Foreground="white" Content="Add stock" Command="{Binding ViewModel.AddStockCommand}"/>
                <ui:Button Grid.Column="1" Margin="0,0,10,10" Grid.Row="14" Height="35" Width="70" Background="Black" Content="refresh" Command="{Binding ViewModel.GetStocksCommand}" />
            </Grid>

            <Grid x:Name="stockDgGrid" Grid.Column="1" Height="300">
                <DataGrid Foreground="Black" ItemsSource="{Binding ViewModel.Stocks}" BorderBrush="Black" BorderThickness="1" />
            </Grid>
        </StackPanel>
    </Grid>
</Page>
