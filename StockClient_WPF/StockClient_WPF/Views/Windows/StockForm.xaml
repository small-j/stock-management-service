<Window x:Class="StockClient_WPF.Views.Windows.StockForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StockClient_WPF.Views.Windows"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="StockForm" Height="450" Width="300">
    <Grid>
        <StackPanel>
            <ui:TextBlock Grid.Row="0" Margin="0, 0, 0, 10">
                <Run Text="Item" />
                <Run Text="*" Foreground="OrangeRed"/>
            </ui:TextBlock>
            <ComboBox Grid.Row="1" IsEditable="True" ItemsSource="{Binding ViewModel.Items}" Text="{Binding ViewModel.SelectedAdministrativeAgency, Mode=TwoWay}" Margin="0,0,0,10" />

            <ui:TextBlock Margin="0, 0, 0, 10">
                <Run Text="Stock Count" />
                <Run Text="*" Foreground="OrangeRed"/>
            </ui:TextBlock>
            <ui:NumberBox Margin="0,0,0,10" Text="{Binding ViewModel.Count}" />

            <ui:Button Grid.Row="14" Height="50" Margin="10,10,10,10" HorizontalAlignment="Stretch" Background="CadetBlue" Foreground="white" Content="Add" Command="{Binding ViewModel.AddCommand}"/>
        </StackPanel>

    </Grid>
</Window>
